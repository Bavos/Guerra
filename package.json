{
  "name": "guerra-remotion-news-video",
  "version": "1.0.0",
  "private": true,
  "description": "Projeto Remotion + React + TypeScript para vídeo estilo portal de notícias",
  "scripts": {
  "start": "remotion studio src/index.ts",
  "build": "tsc --noEmit",
  "render": "remotion render src/index.ts Video out/video-final.mp4 --props=src/data/input.json --codec=h264 --overwrite"
  }"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "remotion": "4.0.268"
  },
  "devDependencies": {
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "typescript": "5.6.3"
  }
}
